{
  "name": "@jensen95/adressevaelger",
  "version": "0.1.0",
  "description": "Enhanced Danish address picker web component and headless search library for adressevaelger.dk (DAWA's successor) — DAWA-style relevance ranking, floor/door unit expansion, street+city fallback, Danish-letter typo folding and request caching.",
  "type": "module",
  "license": "MIT",
  "author": "Morten Jensen",
  "homepage": "https://jensen95.github.io/adressevealger-dawa-like-search/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jensen95/adressevealger-dawa-like-search.git"
  },
  "bugs": {
    "url": "https://github.com/Jensen95/adressevealger-dawa-like-search/issues"
  },
  "keywords": [
    "adressevaelger",
    "dawa",
    "address",
    "autocomplete",
    "denmark",
    "danish",
    "web-component",
    "lit",
    "custom-element"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": [
    "./dist/components/adressevaelger-search.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "customElements": "custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./component": {
      "types": "./dist/components/adressevaelger-search.d.ts",
      "import": "./dist/components/adressevaelger-search.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && npm run analyze",
    "build:site": "vite build --config vite.site.config.ts",
    "dev": "vite --config vite.site.config.ts",
    "preview": "vite preview --config vite.site.config.ts",
    "analyze": "cem analyze --config custom-elements-manifest.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint && prettier --check .",
    "format": "prettier --write .",
    "bench": "node scripts/benchmark.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitest/coverage-v8": "^4.1.10",
    "chart.js": "^4.4.7",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "oxlint": "^1.73.0",
    "prettier": "^3.4.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
